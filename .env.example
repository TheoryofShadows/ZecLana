# --- NEAR Intents 1Click swap backend (ZEC <-> Solana) ---
# The swap works with NO configuration: the 1Click API is public, non-custodial,
# and requires no account or KYC. These variables are optional overrides.

# Base URL for the 1Click API. Defaults to the public endpoint.
# ONECLICK_BASE_URL=https://1click.chaindefuser.com

# Optional JWT for better solver rates / higher limits. Not required for swaps.
# Request one from the NEAR Intents team if you need it.
# ONECLICK_JWT=
